                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /><RowDefinition Height="64" /></Grid.RowDefinitions>
                                <Grid Margin="18,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Mappen" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="Automatische bewaking" />
                                </Grid>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding WatchedFolders}" SelectedItem="{Binding SelectedWatchedFolder}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PAD" Width="*" Binding="{Binding Path}" />
                                        <DataGridCheckBoxColumn Header="ACTIEF" Width="90" Binding="{Binding IsEnabled}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="18,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AddWatchedFolderCommand}">
                                        <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8F4;" /><TextBlock Text="Map toevoegen" /></StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource DangerButtonStyle}" Command="{Binding RemoveWatchedFolderCommand}" Content="Verwijderen" />
                                    <Button Grid.Column="3" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveWatchedFoldersCommand}" Content="Wijzigingen opslaan" />
                                </Grid>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Border Width="44" Height="44" HorizontalAlignment="Left" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource AccentBrush}" Text="&#xE8B7;" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionTitleStyle}" Text="Direct op de hoogte" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource PageSubtitleStyle}" Text="Na het opslaan start de bewaking opnieuw. Nieuwe bestanden verschijnen daarna automatisch als voorstel." />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,12,0,0" Padding="14" Background="{DynamicResource WarningSoftBrush}" CornerRadius="7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,1,10,0" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" />
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="Gebruik bij voorkeur lokale mappen of stabiele netwerklocaties." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="108" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Opruimscan" />
