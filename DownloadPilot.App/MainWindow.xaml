                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="VEILIGHEID" />
                                    <Border Padding="12" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding SelectedProposal.SafetyLabel}" />
                                            <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding SelectedProposal.SafetyExplanation}" TextWrapping="Wrap" TextTrimming="None" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="DOELMAP" />
