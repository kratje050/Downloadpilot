                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PROEFMODUS" />
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding SelectedProposal.DryRunAction}" TextWrapping="Wrap" TextTrimming="None" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="SNELLE PREVIEW" />
                                    <Border Height="178" Padding="12" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7">
                                        <Grid>
                                            <Image Source="{Binding SelectedPreviewImagePath}" Stretch="Uniform" Visibility="{Binding IsSelectedPreviewImageVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsSelectedPreviewTextVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding SelectedPreviewText}" TextWrapping="Wrap" TextTrimming="None" />
                                            </ScrollViewer>
                                            <StackPanel VerticalAlignment="Center" Visibility="{Binding IsSelectedPreviewFallbackVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="22" Foreground="{DynamicResource AccentBrush}" Text="&#xE8A5;" />
                                                <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding SelectedPreviewTitle}" />
                                                <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding SelectedPreviewText}" TextWrapping="Wrap" TextTrimming="None" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenSelectedOriginalCommand}">
