<Window x:Class="DownloadPilot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DownloadPilot"
        Icon="Assets/DownloadPilot.ico"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navigation -->
        <Border Grid.RowSpan="2" Background="{DynamicResource NavBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="88" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="116" />
                </Grid.RowDefinitions>

                <Grid Margin="22,20,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Width="40" Height="40" Source="Assets/DownloadPilot-icon.png" Stretch="Uniform" />
                    <StackPanel Grid.Column="1" Margin="10,1,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White" Text="DownloadPilot" />
                        <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource NavMutedBrush}" Text="LOKAAL BESTANDSBEHEER" />
                    </StackPanel>
                </Grid>

                <ListBox x:Name="NavigationList"
                         Grid.Row="1"
                         SelectedIndex="0"
                         Style="{StaticResource NavigationListStyle}"
                         ItemContainerStyle="{StaticResource NavigationItemStyle}">
                    <ListBoxItem Tag="Overzicht">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE80F;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Overzicht" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Slimme inbox">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE950;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Slimme inbox" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Slimme tools">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE71D;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Slimme tools" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Mailfilter">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE715;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Mailfilter" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Nieuwe bestanden">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8A5;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Nieuwe bestanden" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Regels">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8FD;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Regels" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Bewaakte mappen">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8B7;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Bewaakte mappen" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Opruimscan">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE9D2;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Opruimscan" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Duplicaten">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8C8;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Duplicaten" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Geschiedenis">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE81C;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Geschiedenis" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Instellingen">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE713;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Instellingen" />
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Over DownloadPilot">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE946;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Over" />
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <Border Grid.Row="2" Margin="14,10,14,16" Padding="12" Background="{DynamicResource NavHoverBrush}" CornerRadius="7">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,1,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Bewaking gepauzeerd" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                                <Setter Property="Text" Value="Bewaking actief" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Margin="16,6,0,0" FontSize="10" Foreground="{DynamicResource NavMutedBrush}" Text="Versie 0.2.3" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Top command bar -->
        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedItem.Tag, ElementName=NavigationList}" />
                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="Alles blijft op deze computer" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Margin="0,0,12,0" Padding="10,6" Background="{DynamicResource AccentSoftBrush}" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentBrush}" Text="&#xE73E;" />
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Text="Lokaal en privé" />
                        </StackPanel>
                    </Border>
                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ScanDownloadsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE721;" />
                            <TextBlock Text="Nu scannen" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,6,0" Style="{StaticResource IconButtonStyle}" Command="{Binding StartMonitoringCommand}" Content="&#xE768;" ToolTip="Bewaking starten" />
                    <Button Style="{StaticResource IconButtonStyle}" Command="{Binding StopMonitoringCommand}" Content="&#xE769;" ToolTip="Bewaking pauzeren" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Pages -->
        <TabControl x:Name="ContentTabs"
                    Grid.Row="1"
                    Grid.Column="1"
                    SelectedIndex="{Binding SelectedIndex, ElementName=NavigationList, Mode=OneWay}"
                    Style="{StaticResource ContentTabStyle}">
            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="108" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Goed overzicht, minder zoekwerk" />
                            <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Bekijk nieuwe voorstellen en houd de organisatie van je bestanden bij." />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource GhostButtonStyle}" Command="{Binding UndoLastCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE7A7;" />
                                <TextBlock Text="Laatste actie terugdraaien" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="5" Margin="-6,14,-6,0">
                        <Border Margin="6,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="BEWAKING" />
                                    <TextBlock Margin="0,3,0,0" FontSize="17" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                <Setter Property="Text" Value="Gepauzeerd" />
                                                <Style.Triggers><DataTrigger Binding="{Binding IsMonitoring}" Value="True"><Setter Property="Text" Value="Actief" /></DataTrigger></Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource InfoSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource InfoBrush}" Text="&#xE8A5;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="NIEUW" />
                                    <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding NewFilesCount}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource AccentBrush}" Text="&#xE930;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="GEORGANISEERD" />
                                    <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding OrganizedFilesCount}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource WarningSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource WarningBrush}" Text="&#xE8C8;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="DUBBEL" />
                                    <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding DuplicateFilesCount}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource AccentBrush}" Text="&#xE9D9;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="RUIMTEWINST" />
                                    <TextBlock Margin="0,3,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding PotentialCleanupSavingsReadable}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.45*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="58" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="18,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Nieuwe voorstellen" />
                                        <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="Selecteer een bestand om het voorstel te bekijken" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding NewFilesCount, StringFormat={}{0} open}" />
                                </Grid>
                                <Grid Grid.Row="1">
                                    <DataGrid ItemsSource="{Binding NewFileProposals}" SelectedItem="{Binding SelectedProposal}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="" Width="46">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="BESTANDSNAAM" Width="2*" Binding="{Binding OriginalFileName}" />
                                            <DataGridTextColumn Header="CATEGORIE" Width="*" Binding="{Binding Category}" />
                                            <DataGridTextColumn Header="SCORE" Width="70" Binding="{Binding Confidence, StringFormat={}{0}%}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="Geen nieuwe voorstellen">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding NewFilesCount}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions><RowDefinition Height="1.08*" /><RowDefinition Height="12" /><RowDefinition Height="0.92*" /></Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Geselecteerd voorstel" />
                                    <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="BESTANDSNAAM" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding SelectedProposal.OriginalFileName}" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="DOELMAP" />
                                        <TextBox Text="{Binding SelectedProposal.TargetFolder, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="NIEUWE NAAM" />
                                        <TextBox Text="{Binding SelectedProposal.TargetFileName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <WrapPanel Grid.Row="2" Margin="0,14,0,0">
                                        <Button Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding MoveSelectedCommand}">
                                            <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8DE;" /><TextBlock Text="Verplaatsen" /></StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DecideLaterCommand}" Content="Later" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="52" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <TextBlock Margin="18,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Laatste acties" />
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentHistory}" RowHeight="38" ColumnHeaderHeight="34">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="TIJD" Width="92" Binding="{Binding TimestampLocal, StringFormat={}{0:HH:mm}}" />
                                            <DataGridTextColumn Header="ACTIE" Width="*" Binding="{Binding ActionType}" />
                                            <DataGridTextColumn Header="STATUS" Width="*" Binding="{Binding Status}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentBrush}" Text="&#xE946;" />
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,20,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="108" />
                            <RowDefinition Height="330" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="300" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="270" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Slimme inbox" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Alle scanresultaten samengevat in acties, risico's, mappen en leersuggesties." />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <ComboBox Width="180" Margin="0,0,8,0" ItemsSource="{Binding WorkflowModes}" SelectedItem="{Binding SelectedWorkflowMode}" />
                                <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ApplyWorkflowModeCommand}" Content="Modus toepassen" />
                                <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshSmartWorkflowCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE72C;" /><TextBlock Text="Verversen" /></StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ProcessSafeQueueCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE762;" /><TextBlock Text="Wachtrij verwerken" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="4" Margin="-6,14,-6,0">
                            <Border Margin="6,0" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="{DynamicResource InfoSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource InfoBrush}" Text="&#xE950;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="INBOX" />
                                        <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding SmartInboxCount}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Margin="6,0" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="DIRECT KLAAR" />
                                        <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding SafeQueueCount}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Margin="6,0" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="{DynamicResource WarningSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="CONTROLEREN" />
                                        <TextBlock Margin="0,3,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding ReviewQueueCount}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Margin="6,0" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="{DynamicResource CoralSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource CoralBrush}" Text="&#xE74D;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="DUBBEL" />
                                        <TextBlock Margin="0,3,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding PotentialDuplicateSavingsReadable}" />
                                    </StackPanel>
