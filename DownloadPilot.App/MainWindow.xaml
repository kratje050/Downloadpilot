                                        </Button>
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RevealSelectedOriginalCommand}">
                                            <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" /><TextBlock Text="In Verkenner" /></StackPanel>
                                        </Button>
