                                        </Button>
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AlwaysApplySelectedCommand}" Content="Altijd toepassen" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RememberRuleForSelectedCommand}" Content="Regel onthouden" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Command="{Binding IgnoreSelectedProposalsCommand}" Content="Aangevinkte negeren" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Command="{Binding DecideLaterCommand}" Content="Later" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Command="{Binding IgnoreSelectedCommand}" Content="Negeren" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Organisatieregels" />
                            <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Bepaal hoe DownloadPilot bestanden herkent, benoemt en verplaatst." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ImportRulesCommand}" Content="Importeren" />
                            <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportRulesCommand}" Content="Exporteren" />
                            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NewRuleCommand}">
                                <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE710;" /><TextBlock Text="Nieuwe regel" /></StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /><RowDefinition Height="58" /></Grid.RowDefinitions>
                                <Grid Margin="18,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="210" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Actieve regels" />
                                    <Grid Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                        <TextBox Padding="32,7,10,7" Text="{Binding RuleSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Regels zoeken" />
                                        <TextBlock Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource TextSecondaryBrush}" IsHitTestVisible="False" Text="&#xE721;" />
                                    </Grid>
                                    <Button Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource IconButtonStyle}" Command="{Binding RefreshRulesCommand}" Content="&#xE72C;" ToolTip="Regels vernieuwen" />
                                </Grid>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding RulesView}" SelectedItem="{Binding SelectedRule}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="NAAM" Width="205" Binding="{Binding Name}" />
                                        <DataGridTextColumn Header="EXT." Width="74" Binding="{Binding ExtensionEquals}" />
                                        <DataGridTextColumn Header="CATEGORIE" Width="160" Binding="{Binding Category}" />
                                        <DataGridTextColumn Header="PRIO" Width="58" Binding="{Binding Priority}" />
                                        <DataGridCheckBoxColumn Header="A" Width="48" Binding="{Binding AutoApply}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="18,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <Button HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SetupAutomaticOrganizationCommand}" Content="Slimme basisregels instellen" />
                                    <Button Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource GhostButtonStyle}" Command="{Binding NewRuleCommand}" Content="Leegmaken" />
                                    <Button Grid.Column="2" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteSelectedRuleCommand}" Content="Verwijderen" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Regel bewerken" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="NAAM" />
                                    <TextBox Text="{Binding RuleEditor.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="EXTENSIE" />
                                            <TextBox Text="{Binding RuleEditor.ExtensionEquals, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PRIORITEIT" />
                                            <TextBox Text="{Binding RuleEditor.Priority, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="BESTANDSNAAM BEVAT" />
                                    <TextBox Text="{Binding RuleEditor.FileNameContains, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="DOELMAP" />
                                    <TextBox Text="{Binding RuleEditor.DestinationFolder, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="CATEGORIE" />
                                    <ComboBox ItemsSource="{Binding AvailableCategories}" SelectedItem="{Binding RuleEditor.Category}" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="HERNOEM-SJABLOON (OPTIONEEL)" />
                                    <TextBox Text="{Binding RuleEditor.RenameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Margin="0,14,0,0" Content="Automatisch uitvoeren" IsChecked="{Binding RuleEditor.AutoApply}" />
                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Button HorizontalAlignment="Stretch" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddRuleCommand}" Content="Regel opslaan" />
                                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding TestRuleCommand}">
                                            <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE9D2;" /><TextBlock Text="Testen" /></StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="REGELTEST" />
                                    <Border Padding="12" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding RuleTestSummary}" TextWrapping="Wrap" TextTrimming="None" />
                                            <DataGrid Margin="0,10,0,0" MaxHeight="180" ItemsSource="{Binding RuleTestResults}" RowHeight="34" ColumnHeaderHeight="30">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="BESTAND" Width="2*" Binding="{Binding OriginalFileName}" />
                                                    <DataGridTextColumn Header="DOELNAAM" Width="2*" Binding="{Binding TargetFileName}" />
                                                    <DataGridTextColumn Header="SCORE" Width="62" Binding="{Binding Confidence, StringFormat={}{0}%}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleStyle}" Text="Bewaakte mappen" />
