                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ScanDownloadsCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE721;" /><TextBlock Text="Downloads scannen" /></StackPanel>
                        </Button>
                    </Grid>
                    <UniformGrid Grid.Row="1" Columns="4" Margin="-6,14,-6,0">
                        <Border Margin="6,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="BESTANDEN" /><TextBlock Margin="0,7,0,0" FontSize="23" FontWeight="SemiBold" Text="{Binding ScanFileCount}" /></StackPanel></Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="TOTALE GROOTTE" /><TextBlock Margin="0,7,0,0" FontSize="23" FontWeight="SemiBold" Text="{Binding ScanTotalSizeReadable}" /></StackPanel></Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="GROOT (100+ MB)" /><TextBlock Margin="0,7,0,0" FontSize="23" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" Text="{Binding ScanLargeFilesCount}" /></StackPanel></Border>
                        <Border Margin="6,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="OUD (30+ DAGEN)" /><TextBlock Margin="0,7,0,0" FontSize="23" FontWeight="SemiBold" Foreground="{DynamicResource CoralBrush}" Text="{Binding ScanOldFilesCount}" /></StackPanel></Border>
                    </UniformGrid>
                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.85*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Verdeling" />
                                <ProgressBar Grid.Row="1" Margin="0,16,0,0" IsIndeterminate="True" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="-6,14,-6,-6">
                                    <Border Margin="6" Padding="16" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="7"><StackPanel><TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Archieven" /><TextBlock Margin="0,6,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding ScanArchiveCount}" /></StackPanel></Border>
                                    <Border Margin="6" Padding="16" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="7"><StackPanel><TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Installatiebestanden" /><TextBlock Margin="0,6,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding ScanInstallerCount}" /></StackPanel></Border>
                                    <Border Margin="6" Padding="16" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="7"><StackPanel><TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Ongecategoriseerd" /><TextBlock Margin="0,6,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding ScanUncategorizedCount}" /></StackPanel></Border>
                                    <Border Margin="6" Padding="16" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="7"><StackPanel><TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Mogelijke duplicaten" /><TextBlock Margin="0,6,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding ScanPossibleDuplicatesCount}" /></StackPanel></Border>
                                </UniformGrid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Border Width="44" Height="44" HorizontalAlignment="Left" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" />
                                </Border>
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionTitleStyle}" Text="Veilig te organiseren" />
                                <TextBlock Margin="0,7,0,0" FontSize="34" FontWeight="SemiBold" Text="{Binding ScanLikelySafeMoveCount}" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="bestanden hebben een betrouwbaarheid van minimaal 85%" />
                                <Border Margin="0,18,0,0" Padding="14" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="Een scan verwijdert of verplaatst nooit automatisch bestanden. Je houdt altijd de controle." />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Mogelijke duplicaten" />
                            <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Bestanden met dezelfde inhoud worden apart gehouden zodat je ze rustig kunt beoordelen." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Border Margin="0,0,8,0" Padding="12,7" Background="{DynamicResource WarningSoftBrush}" CornerRadius="6">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" Text="{Binding DuplicateFilesCount, StringFormat={}{0} gevonden}" />
                            </Border>
                            <Button Style="{StaticResource DangerButtonStyle}" Command="{Binding MoveSelectedDuplicatesToRecycleBinCommand}">
                                <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE74D;" /><TextBlock Text="Naar Prullenbak" /></StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /><RowDefinition Height="62" /></Grid.RowDefinitions>
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="240" /></Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Dubbele bestanden" />
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBox Padding="32,7,10,7" Text="{Binding DuplicateSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Duplicaten zoeken" />
                                    <TextBlock Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource TextSecondaryBrush}" IsHitTestVisible="False" Text="&#xE721;" />
                                </Grid>
                            </Grid>
                            <Grid Grid.Row="1">
                                <DataGrid ItemsSource="{Binding DuplicateProposalsView}" SelectedItem="{Binding SelectedProposal}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="46">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="BESTANDSNAAM" Width="2*" Binding="{Binding OriginalFileName}" />
                                        <DataGridTextColumn Header="CATEGORIE" Width="*" Binding="{Binding Category}" />
                                        <DataGridTextColumn Header="GROOTTE" Width="100" Binding="{Binding FileSizeReadable}" />
                                        <DataGridTextColumn Header="REDEN" Width="2*" Binding="{Binding Reason}" />
                                        <DataGridTextColumn Header="VOORGESTELDE MAP" Width="2*" Binding="{Binding TargetFolder}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" />
                                    <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Geen duplicaten gevonden" />
                                    <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DuplicateProposalsView.IsEmpty}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="2" Margin="18,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding SelectedDuplicateProposalsCount, StringFormat=DownloadPilot ruimt alleen {0} aangevinkte duplicaten op na bevestiging.}" />
                                <Button Grid.Column="1" Margin="0,0,6,0" Style="{StaticResource IconButtonStyle}" Command="{Binding SelectAllDuplicatesCommand}" Content="&#xE8E1;" ToolTip="Alle zichtbare duplicaten aanvinken" />
                                <Button Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource IconButtonStyle}" Command="{Binding ClearDuplicateSelectionCommand}" Content="&#xE711;" ToolTip="Vinkjes wissen" />
                                <Button Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding IgnoreSelectedCommand}" Content="Rij negeren" />
                                <Button Grid.Column="4" Style="{StaticResource DangerButtonStyle}" Command="{Binding MoveSelectedDuplicatesToRecycleBinCommand}" Content="Aangevinkte naar Prullenbak" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="24,20,24,18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Geschiedenis" />
                            <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Bekijk wat er is gebeurd en herstel een geselecteerde verplaatsing." />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="58" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="240" /><ColumnDefinition Width="190" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Acties" />
                                <Grid Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <TextBox Padding="32,7,10,7" Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Geschiedenis zoeken" />
                                    <TextBlock Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource TextSecondaryBrush}" IsHitTestVisible="False" Text="&#xE721;" />
                                </Grid>
                                <ComboBox Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center" ItemsSource="{Binding HistoryFilters}" SelectedItem="{Binding SelectedHistoryFilter}" />
                                <Button Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RollbackCurrentSessionCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE7A7;" /><TextBlock Text="{Binding SessionUndoableCount, StringFormat=Sessie herstellen ({0})}" /></StackPanel>
                                </Button>
                                <Button Grid.Column="4" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UndoSelectedHistoryCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE7A7;" /><TextBlock Text="Selectie herstellen" /></StackPanel>
                                </Button>
                            </Grid>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding RecentHistoryView}" SelectedItem="{Binding SelectedHistoryEntry}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="DATUM EN TIJD" Width="140" Binding="{Binding TimestampLocal, StringFormat={}{0:dd-MM-yyyy HH:mm}}" />
                                    <DataGridTextColumn Header="ACTIE" Width="100" Binding="{Binding ActionType}" />
                                    <DataGridTextColumn Header="ORIGINEEL" Width="1.3*" Binding="{Binding OriginalName}" />
                                    <DataGridTextColumn Header="NIEUWE NAAM" Width="1.3*" Binding="{Binding NewName}" />
                                    <DataGridTextColumn Header="REGEL" Width="*" Binding="{Binding RuleName}" />
                                    <DataGridTextColumn Header="STATUS" Width="100" Binding="{Binding Status}" />
                                    <DataGridTextColumn Header="MELDING" Width="2*" Binding="{Binding ErrorMessage}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,20,24,24">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Instellingen" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Pas automatisering, privacy en lokaal onderhoud aan." />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ReloadSettingsCommand}" Content="Opnieuw laden" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveSettingsCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE74E;" /><TextBlock Text="Opslaan" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.95*" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Automatisering" />
                                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Bepaal wanneer DownloadPilot een voorstel zelfstandig mag uitvoeren." />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PROFIEL" />
                                        <ComboBox Width="210" HorizontalAlignment="Left" ItemsSource="{Binding WorkflowModes}" SelectedItem="{Binding SettingsEditor.OrganizationProfile}" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="MINIMALE BETROUWBAARHEID (0-100)" />
                                        <TextBox Width="130" HorizontalAlignment="Left" Text="{Binding SettingsEditor.MinAutoApplyConfidence, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="STANDAARD DOELMAP" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource IconButtonStyle}" Command="{Binding ChooseDefaultDestinationRootCommand}" Content="&#xE8B7;" ToolTip="Doelmap kiezen" />
                                            <TextBox Text="{Binding SettingsEditor.DefaultDestinationRoot, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="THEMA" />
                                        <ComboBox Width="190" HorizontalAlignment="Left" ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SettingsEditor.Theme}" />
                                        <CheckBox Margin="0,16,0,0" Content="Start DownloadPilot met Windows" IsChecked="{Binding SettingsEditor.StartWithWindows}" />
                                        <CheckBox Margin="0,10,0,0" Content="Bij opstarten op GitHub controleren op updates" IsChecked="{Binding SettingsEditor.UpdateChecksEnabled}" />
                                        <CheckBox Margin="0,10,0,0" Content="Updates alvast downloaden na bevestiging" IsChecked="{Binding SettingsEditor.AutoDownloadUpdates}" />
                                        <DockPanel Margin="0,12,0,0">
                                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CheckForUpdatesCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE895;" />
                                                    <TextBlock Text="Nu controleren" />
                                                </StackPanel>
                                            </Button>
                                            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding UpdateStatus}" TextWrapping="Wrap" TextTrimming="None" />
                                        </DockPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="OPRUIMPLANNING" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RegisterCleanupScheduleCommand}" Content="Planning opslaan" />
                                            <ComboBox ItemsSource="{Binding CleanupSchedules}" SelectedItem="{Binding SettingsEditor.CleanupSchedule}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding CleanupScheduleStatus}" TextWrapping="Wrap" TextTrimming="None" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Analyse" />
                                        <CheckBox Margin="0,12,0,0" Content="OCR inschakelen voor gescande documenten" IsChecked="{Binding SettingsEditor.OcrEnabled}" />
                                        <CheckBox Content="Bestanden vergelijken met SHA-256-hashes" IsChecked="{Binding SettingsEditor.HashCheckEnabled}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="52" /><RowDefinition Height="150" /><RowDefinition Height="52" /><RowDefinition Height="150" /><RowDefinition Height="58" /></Grid.RowDefinitions>
                                        <Grid Margin="18,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Extra auditmappen" />
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Voor Power-audit en opslagkaart." />
                                            </StackPanel>
                                            <Button Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AddExtraScanPathCommand}" Content="Map toevoegen" />
                                        </Grid>
                                        <DataGrid Grid.Row="1" ItemsSource="{Binding ExtraScanPathItems}" RowHeight="34" ColumnHeaderHeight="30">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="42">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="MAP" Width="*" Binding="{Binding Detail}" />
                                                <DataGridTextColumn Header="STATUS" Width="90" Binding="{Binding Metric}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock Grid.Row="2" Margin="18,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Genegeerde auditpaden" />
                                        <DataGrid Grid.Row="3" ItemsSource="{Binding IgnoredPathItems}" RowHeight="34" ColumnHeaderHeight="30">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="42">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="PAD" Width="*" Binding="{Binding Detail}" />
                                                <DataGridTextColumn Header="STATUS" Width="90" Binding="{Binding Metric}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <WrapPanel Grid.Row="4" Margin="18,10" HorizontalAlignment="Right">
                                            <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RemoveSelectedExtraScanPathsCommand}" Content="Extra selectie verwijderen" />
                                            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RemoveSelectedIgnoredPathsCommand}" Content="Genegeerde selectie verwijderen" />
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Privacy en meldingen" />
                                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Alle verwerking vindt lokaal plaats. Er worden geen bestanden geüpload." />
                                        <CheckBox Margin="0,14,0,0" Content="Meldingen in het systeemvak tonen" IsChecked="{Binding SettingsEditor.NotificationsEnabled}" />
                                        <CheckBox Content="Documenttekst lokaal opslaan indien nodig" IsChecked="{Binding SettingsEditor.StoreDocumentText}" />
                                        <CheckBox Content="Ik begrijp welke lokale mappen DownloadPilot mag scannen" IsChecked="{Binding SettingsEditor.PermissionNoticeAccepted}" />
                                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding PermissionSummary}" TextWrapping="Wrap" TextTrimming="None" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Onderhoud" />
                                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Beheer lokale back-ups en hoe lang de actiegeschiedenis bewaard blijft." />
                                        <CheckBox Margin="0,14,0,0" Content="Automatisch databaseback-ups maken" IsChecked="{Binding SettingsEditor.AutomaticBackupsEnabled}" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="GESCHIEDENIS BEWAREN (DAGEN, 0 = ONBEPERKT)" />
                                        <TextBox Width="130" HorizontalAlignment="Left" Text="{Binding SettingsEditor.HistoryRetentionDays, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Margin="0,16,0,0" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RestartOnboardingCommand}" Content="Introductie opnieuw tonen" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Margin="0,14,0,0" Padding="14" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,1,10,0" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentBrush}" Text="&#xE73E;" />
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Instellingen en databaseback-ups blijven lokaal in je gebruikersprofiel." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,20,24,24">
                        <Grid.RowDefinitions><RowDefinition Height="210" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="8">
                            <Grid Margin="28">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="240" /></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource OnAccentBrush}" Text="DOWNLOADPILOT 0.2.3" />
                                    <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="SemiBold" Foreground="{DynamicResource OnAccentBrush}" Text="Rust in je Downloads-map" />
                                    <TextBlock Margin="0,10,0,0" MaxWidth="600" HorizontalAlignment="Left" FontSize="14" Foreground="{DynamicResource OnAccentBrush}" Opacity="0.82" TextWrapping="Wrap" TextTrimming="None" Text="Een lokale Windows-assistent die bestanden herkent, voorstellen doet en alleen handelt wanneer jij dat toestaat." />
                                    <Button Margin="0,16,0,0" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CheckForUpdatesCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE895;" />
                                            <TextBlock Text="Updates controleren" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Image Grid.Column="1" Width="112" Height="112" HorizontalAlignment="Center" VerticalAlignment="Center" Source="Assets/DownloadPilot-icon.png" Stretch="Uniform" />
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Border Width="42" Height="42" HorizontalAlignment="Left" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource SuccessBrush}" Text="&#xE72E;" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionTitleStyle}" Text="Privacy voorop" />
                                    <TextBlock Margin="0,9,0,0" Style="{StaticResource PageSubtitleStyle}" Text="Geen cloud, geen account, geen telemetrie en geen automatische uploads. Je gegevens blijven in de lokale SQLite-database." />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Border Width="42" Height="42" HorizontalAlignment="Left" Background="{DynamicResource InfoSoftBrush}" CornerRadius="7">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource InfoBrush}" Text="&#xE943;" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionTitleStyle}" Text="Gebouwd voor Windows" />
                                    <TextBlock Margin="0,9,0,0" Style="{StaticResource PageSubtitleStyle}" Text="C#, .NET 8, WPF, MVVM, SQLite en veilige undo-registratie voor iedere verplaatsing." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Update dialog -->
        <Grid Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Panel.ZIndex="120"
              Background="#B8191B1F"
              Visibility="{Binding IsUpdateDialogVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="620"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Height="126"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="8,8,0,0">
                        <Grid Margin="24,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <Border HorizontalAlignment="Left" Padding="10,5" Background="#29FFFFFF" CornerRadius="6">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource OnAccentBrush}" Text="{Binding UpdateDialogBadge}" />
                                </Border>
                                <TextBlock Margin="0,12,0,0" FontSize="23" FontWeight="SemiBold" Foreground="{DynamicResource OnAccentBrush}" Text="{Binding UpdateDialogTitle}" TextTrimming="None" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    Margin="0,18,0,0"
                                    Background="#24FFFFFF"
                                    BorderBrush="#35FFFFFF"
                                    Foreground="{DynamicResource OnAccentBrush}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Command="{Binding DismissUpdateDialogCommand}"
                                    Content="&#xE711;"
                                    FontFamily="Segoe Fluent Icons"
                                    ToolTip="Sluiten" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="26,24,26,22">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" HorizontalAlignment="Left" VerticalAlignment="Top" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{DynamicResource AccentBrush}" Text="{Binding UpdateDialogIcon}" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding UpdateDialogSubtitle}" TextWrapping="Wrap" TextTrimming="None" />
                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding UpdateDialogDetail}" TextWrapping="Wrap" TextTrimming="None" />

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{DynamicResource SurfaceMutedBrush}"
                                    CornerRadius="8"
                                    Visibility="{Binding IsUpdateDialogProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="10" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding UpdateDownloadSizeText}" TextWrapping="Wrap" TextTrimming="None" />
                                        <TextBlock Grid.Column="1" Margin="16,0,0,0" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Text="{Binding UpdateDownloadProgressText}" />
                                    </Grid>
                                    <ProgressBar Grid.Row="2"
                                                 Height="9"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding UpdateDownloadProgress}"
                                                 IsIndeterminate="{Binding IsUpdateDownloadIndeterminate}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="26,0,26,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding UpdateStatus}" TextWrapping="Wrap" TextTrimming="None" />
                        <WrapPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                            <Button Margin="0,0,8,0" Style="{StaticResource GhostButtonStyle}" Command="{Binding DismissUpdateDialogCommand}" Content="Later" />
                            <Button Margin="0,0,8,0" Command="{Binding OpenUpdateReleaseCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanOpenUpdateRelease}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8A7;" />
                                    <TextBlock Text="GitHub openen" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DownloadUpdateCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanDownloadUpdate}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE896;" />
                                    <TextBlock Text="Downloaden" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding InstallDownloadedUpdateCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanInstallDownloadedUpdate}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE73E;" />
                                    <TextBlock Text="Installeren" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- First-run setup -->
        <Grid x:Name="OnboardingOverlay"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Panel.ZIndex="100"
              Background="#B8191B1F"
              Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="780"
                    Height="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="82" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="76" />
                    </Grid.RowDefinitions>

                    <Grid Margin="26,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Image Width="42" Height="42" VerticalAlignment="Center" Source="Assets/DownloadPilot-icon.png" Stretch="Uniform" />
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" FontWeight="SemiBold" Text="DownloadPilot instellen" />
                            <TextBlock Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Een rustige start in vijf korte stappen" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding OnboardingStepNumber, StringFormat=Stap {0} van 5}" />
                    </Grid>
                    <ProgressBar Grid.Row="1" Maximum="100" Value="{Binding OnboardingProgress, Mode=OneWay}" />

                    <Grid Grid.Row="2" Margin="34,26,34,18">
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Welkom bij DownloadPilot" />
                                <TextBlock Margin="0,12,0,0" MaxWidth="430" HorizontalAlignment="Left" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="DownloadPilot houdt nieuwe downloads overzichtelijk met duidelijke voorstellen. Jij bepaalt altijd wat er wordt verplaatst." />
                                <StackPanel Margin="0,24,0,0">
                                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal"><TextBlock Width="28" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" /><TextBlock Text="Volledig lokaal, zonder account of cloud" /></StackPanel>
                                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal"><TextBlock Width="28" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" /><TextBlock Text="Nooit automatisch verwijderen of overschrijven" /></StackPanel>
                                    <StackPanel Orientation="Horizontal"><TextBlock Width="28" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" /><TextBlock Text="Iedere verplaatsing kan worden hersteld" /></StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Width="210" Height="210" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8">
                                <Image Width="126" Height="126" Source="Assets/DownloadPilot-icon.png" Stretch="Uniform" />
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="1"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                            </Grid.Style>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Welke mappen wil je bewaken?" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Je Downloads-map is standaard toegevoegd. Extra lokale mappen kun je hier meteen kiezen." />
                            </StackPanel>
                            <Border Grid.Row="1" Margin="0,18,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7">
                                <DataGrid ItemsSource="{Binding WatchedFolders}" SelectedItem="{Binding SelectedWatchedFolder}" RowHeight="42">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="MAP" Width="*" Binding="{Binding Path}" />
                                        <DataGridCheckBoxColumn Header="ACTIEF" Width="90" Binding="{Binding IsEnabled}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <StackPanel Grid.Row="2" Margin="0,14,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AddWatchedFolderCommand}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8F4;" /><TextBlock Text="Map toevoegen" /></StackPanel>
                                </Button>
                                <Button Style="{StaticResource DangerButtonStyle}" Command="{Binding RemoveWatchedFolderCommand}" Content="Selectie verwijderen" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="2"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                            </Grid.Style>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Kies de georganiseerde hoofdmap" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Binnen deze map maakt DownloadPilot categorieën zoals Documenten, Afbeeldingen en Archieven." />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,28,0,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="STANDAARD DOELMAP" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ChooseDefaultDestinationRootCommand}">
                                        <StackPanel Orientation="Horizontal"><TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" /><TextBlock Text="Kiezen" /></StackPanel>
                                    </Button>
                                    <TextBox Text="{Binding SettingsEditor.DefaultDestinationRoot, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>
                            <Border Grid.Row="2" Margin="0,28,0,0" Padding="18" Background="{DynamicResource AccentSoftBrush}" CornerRadius="7">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{DynamicResource AccentBrush}" Text="&#xE8B7;" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold" Text="Voorbeeldstructuur" />
                                        <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="DownloadPilot\Documenten\Facturen" />
                                        <TextBlock Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="DownloadPilot\Afbeeldingen" />
                                        <TextBlock Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="DownloadPilot\Software\Installatiebestanden" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="3"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Hoeveel wil je automatiseren?" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Veilig handmatig is de standaard. Automatische basisregels worden alleen toegevoegd na jouw keuze." />
                                <TextBlock Margin="0,28,0,6" Style="{StaticResource FieldLabelStyle}" Text="WERKWIJZE" />
                                <ComboBox Width="330" HorizontalAlignment="Left" ItemsSource="{Binding OnboardingModes}" SelectedItem="{Binding SelectedOnboardingMode}" />
                                <Border Margin="0,22,0,0" Padding="18" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Veilig handmatig" />
                                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="Nieuwe bestanden verschijnen als voorstel. Er gebeurt pas iets nadat jij op Verplaatsen klikt." />
                                        <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Automatisch met basisregels" />
                                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="Bekende bestandstypen kunnen bij voldoende betrouwbaarheid automatisch worden georganiseerd. Iedere actie blijft herstelbaar." />
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="0,20,0,5" Style="{StaticResource FieldLabelStyle}" Text="MINIMALE BETROUWBAARHEID VOOR AUTOMATISCH (0-100)" />
                                <TextBox Width="130" HorizontalAlignment="Left" Text="{Binding SettingsEditor.MinAutoApplyConfidence, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="32" /><ColumnDefinition Width="0.95*" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Klaar om te beginnen" />
                                <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="Controleer de laatste voorkeuren. Alles kan later bij Instellingen worden aangepast." />
                                <CheckBox Margin="0,24,0,0" Content="Meldingen in het systeemvak tonen" IsChecked="{Binding SettingsEditor.NotificationsEnabled}" />
                                <CheckBox Margin="0,10,0,0" Content="Bij opstarten automatisch op GitHub controleren op updates" IsChecked="{Binding SettingsEditor.UpdateChecksEnabled}" />
                                <CheckBox Margin="0,10,0,0" Content="DownloadPilot starten met Windows" IsChecked="{Binding SettingsEditor.StartWithWindows}" />
                                <CheckBox Margin="0,10,0,0" Content="Automatische lokale databaseback-ups maken" IsChecked="{Binding SettingsEditor.AutomaticBackupsEnabled}" />
                                <Border Margin="0,24,0,0" Padding="14" Background="{DynamicResource SuccessSoftBrush}" CornerRadius="7">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,1,10,0" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SuccessBrush}" Text="&#xE73E;" />
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextTrimming="None" Text="Geen cloud, geen telemetrie en geen verwijderacties." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Voorbeelden" />
                                <TextBlock Margin="0,6,0,18" Style="{StaticResource PageSubtitleStyle}" Text="Dit soort regels kun je gebruiken of later zelf aanpassen." />
                                <StackPanel Margin="0,0,0,14" Orientation="Horizontal"><TextBlock Width="30" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource InfoBrush}" Text="&#xE8A5;" /><TextBlock Text="PDF-facturen naar Documenten\Facturen" /></StackPanel>
                                <StackPanel Margin="0,0,0,14" Orientation="Horizontal"><TextBlock Width="30" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource WarningBrush}" Text="&#xE8A5;" /><TextBlock Text="ZIP-bestanden naar Archieven" /></StackPanel>
                                <StackPanel Orientation="Horizontal"><TextBlock Width="30" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentBrush}" Text="&#xE8A5;" /><TextBlock Text="EXE- en MSI-bestanden naar Software" /></StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid Margin="26,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Button VerticalAlignment="Center" Style="{StaticResource GhostButtonStyle}" Command="{Binding SkipOnboardingCommand}" Content="Overslaan" />
                            <Button Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PreviousOnboardingCommand}" Content="Vorige" />
                            <Button Grid.Column="3" VerticalAlignment="Center" Command="{Binding NextOnboardingCommand}" Content="Volgende">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="3" VerticalAlignment="Center" Command="{Binding CompleteOnboardingCommand}" Content="Installatie afronden">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers><DataTrigger Binding="{Binding OnboardingStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
