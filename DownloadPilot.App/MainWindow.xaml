                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="BESTANDSNAAM" Width="2*" Binding="{Binding OriginalFileName}" />
                                            <DataGridTextColumn Header="CATEGORIE" Width="*" Binding="{Binding Category}" />
                                            <DataGridTextColumn Header="GROOTTE" Width="90" Binding="{Binding FileSizeReadable}" />
                                            <DataGridTextColumn Header="SCORE" Width="70" Binding="{Binding Confidence, StringFormat={}{0}%}" />
                                            <DataGridTextColumn Header="VEILIG" Width="105" Binding="{Binding SafetyLabel}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="Je bent helemaal bij">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding NewFileProposalsView.IsEmpty}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
